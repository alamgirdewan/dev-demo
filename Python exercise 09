import random

class Car:
    def __init__(self, registration_number, max_speed):
        self.registration_number = registration_number
        self.max_speed = max_speed
        self.speed = 0
        self.travelled_distance = 0

    def accelerate(self, change):
        self.speed += change
        if self.speed > self.max_speed:
            self.speed = self.max_speed
        if self.speed < 0:
            self.speed = 0

    def drive(self, hours):
        self.travelled_distance += self.speed * hours

cars = []
for i in range(10):
    cars.append(Car(f"ABC-{i+1}", random.randint(100, 200)))

while True:
    for c in cars:
        c.accelerate(random.randint(-10, 15))
        c.drive(1)
    if any(c.travelled_distance >= 10000 for c in cars):
        break

print(f"{'Reg':<10} {'Max Speed':>10} {'Speed':>8} {'Distance':>10}")

for c in cars:
    print(f"{c.registration_number:<10} {c.max_speed:>7} km/h {c.speed:>5} km/h {c.travelled_distance:>7.1f} km")
