class Elevator:
    def __init__(self, lowest, highest):
        self.lowest = lowest
        self.highest = highest
        self.current = lowest

    def floor_up(self):
        if self.current < self.highest:
            self.current += 1
        print("Floor:", self.current)

    def floor_down(self):
        if self.current > self.lowest:
            self.current -= 1
        print("Floor:", self.current)

    def go_to_floor(self, destination):
        if destination < self.lowest or destination > self.highest:
            print("Floor out of range!")
            return
        if destination > self.current:
            while self.current != destination:
                self.floor_up()
        else:
            while self.current != destination:
                self.floor_down()


h = Elevator(0, 10)
print("Going to floor 5:")
h.go_to_floor(5)
print("Back to bottom:")
h.go_to_floor(0)
print()


