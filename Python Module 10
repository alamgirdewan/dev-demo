import random

class Car:
    def __init__(self, reg_number, max_speed):
        self.reg_number = reg_number
        self.max_speed = max_speed
        self.current_speed = 0
        self.km_driven = 0

    def drive(self, hours=1):
        self.km_driven += self.current_speed * hours


class Race:
    def __init__(self, race_name, total_km, car_list):
        self.race_name = race_name
        self.total_km = total_km
        self.car_list = car_list

    def hour_passes(self):
        for car in self.car_list:
            adjustment = random.randint(-10, 15)
            car.current_speed = max(0, min(car.max_speed, car.current_speed + adjustment))
            car.drive()

    def print_status(self):
        header = f"{'Car':<10}  {'Max speed':>7}  {'Car speed':>7}  {'Distance':>10}"
        print(f"\n[ {self.race_name} ]")
        print(header)

        for car in self.car_list:
            print(f"{car.reg_number:<10}  {car.max_speed:>7}  {car.current_speed:>7}  {car.km_driven:>9.1f}")

    def race_finished(self):
        for car in self.car_list:
            if car.km_driven >= self.total_km:
                return True
        return False


car_list = [Car(f"CAR-{i+1}", random.randint(100, 200)) for i in range(10)]
derby = Race("Grand Demolition Derby", 8000, car_list)

elapsed = 0
while not derby.race_finished():
    derby.hour_passes()
    elapsed += 1
    if elapsed % 10 == 0:
        print(f"After {elapsed} hours:")
        derby.print_status()

print(f"\nRace over! Total time: {elapsed} hours")
derby.print_status()
