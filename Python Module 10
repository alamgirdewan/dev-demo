class Building:
    def __init__(self, lowest, highest, elevator_count):
        self.lowest = lowest
        self.highest = highest
        self.elevators = []
        for _ in range(elevator_count):
            self.elevators.append(Elevator(lowest, highest))

    def run_elevator(self, index, destination):
        print(f"Elevator {index} heading to floor {destination}:")
        self.elevators[index].go_to_floor(destination)

    def fire_alarm(self):
        print("\nFire Alarm! All elevators returning to ground floor.")
        num = 1
        for e in self.elevators:
            print(f"Elevator {num}:")
            e.go_to_floor(self.lowest)
            num += 1

